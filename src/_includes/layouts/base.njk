<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{% if title %}{{ title }} · {% endif %}{{ site.name }}</title>
  <meta name="description" content="{{ description or site.description }}">
  <link rel="icon" type="image/png" href="/assets/img/seal-192.png">
  <link rel="apple-touch-icon" href="/assets/img/seal-192.png">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="{{ site.name }}">
  <meta property="og:title" content="{% if title %}{{ title }} · {% endif %}{{ site.name }}">
  <meta property="og:description" content="{{ description or site.description }}">
  <meta property="og:image" content="{{ site.url }}/assets/img/pfs-seal.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&family=Source+Sans+3:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/main.css?v={{ assetVersion }}">
  {% if site.analyticsId %}
  <script async src="https://www.googletagmanager.com/gtag/js?id={{ site.analyticsId }}"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', '{{ site.analyticsId }}', { anonymize_ip: true, allow_google_signals: false, allow_ad_personalization_signals: false });
  </script>
  {% endif %}
</head>
<body>
<div class="site">
  {% include "partials/header.njk" %}
  {% if site.venueBanner.show %}
  <div class="venue-banner">
    <span class="venue-banner__long">{{ site.venueBanner.longLead }} <a href="{{ site.venueBanner.venueUrl }}" target="_blank" rel="noopener">{{ site.venueBanner.venueName }}</a>.</span>
    <span class="venue-banner__short">{{ site.venueBanner.shortLead }} <a href="{{ site.venueBanner.venueUrl }}" target="_blank" rel="noopener">{{ site.venueBanner.venueName }}</a>.</span>
  </div>
  {% endif %}
  <main class="site__main">
    {{ content | safe }}
  </main>
  {% include "partials/popover.njk" %}
  {% include "partials/footer.njk" %}
</div>
<script src="/assets/js/main.js?v={{ assetVersion }}" defer></script>
</body>
</html>
