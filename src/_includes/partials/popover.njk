<div class="welcome" id="welcome-popover" hidden>
  <div class="welcome__card" role="dialog" aria-modal="true" aria-labelledby="welcome-title">
    <button class="welcome__close" type="button" aria-label="Close" data-welcome-dismiss>×</button>
    <img src="/assets/img/seal-192.png" alt="" width="96" height="96">
    <h2 class="welcome__title" id="welcome-title">Stay in the loop</h2>
    <p class="welcome__copy">Get the monthly meeting program, competition announcements, and club news — one email a month, no spam.</p>
    <div class="welcome__success" hidden>Almost done — check your email to confirm your subscription.</div>
    <form class="welcome__form" novalidate>
      <div class="welcome__name-row">
        <input class="welcome__input" type="text" id="pop-fname" name="fname" placeholder="First name" autocomplete="given-name" aria-label="First name" required>
        <input class="welcome__input" type="text" id="pop-lname" name="lname" placeholder="Last name" autocomplete="family-name" aria-label="Last name" required>
      </div>
      <div class="welcome__submit-row">
        <input class="welcome__input" type="email" placeholder="you@email.com" autocomplete="email" aria-label="Email address" required>
        <button class="btn btn--amber" type="submit">Sign Up</button>
      </div>
      <p class="welcome__error" role="alert" hidden></p>
    </form>
    <div class="welcome__divider"><span></span><em>Or</em><span></span></div>
    <div class="welcome__actions">
      <a class="btn btn--dark" href="/join/" data-analytics="popover_join_click" data-welcome-dismiss>Join the Society</a>
    </div>
    <button class="welcome__later" type="button" data-welcome-dismiss>Maybe later</button>
  </div>
</div>
