---
permalink: /mobile/
eleventyExcludeFromCollections: true
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Mobile preview · {{ site.name }}</title>
  <meta name="robots" content="noindex">
  <link rel="icon" type="image/png" href="/assets/img/seal-192.png">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@500;600;700&family=Source+Sans+3:wght@400;600&display=swap" rel="stylesheet">
  <script>
    // On a real mobile-size screen the main site already renders the mobile
    // layout — skip the frame and go straight there.
    if (window.matchMedia("(max-width: 900px)").matches) {
      window.location.replace(document.querySelector("link[rel=icon]").href.replace(/assets\/img\/seal-192\.png$/, ""));
    }
  </script>
  <style>
    body {
      margin: 0;
      min-height: 100vh;
      background: #23241A;
      color: #C9C4AC;
      font-family: 'Source Sans 3', sans-serif;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 20px;
      padding: 32px 24px 48px;
      box-sizing: border-box;
    }
    .head { display: flex; flex-direction: column; align-items: center; gap: 8px; text-align: center; }
    .head img { width: 64px; height: 64px; object-fit: contain; }
    h1 {
      font-family: Oswald, sans-serif;
      font-weight: 700;
      font-size: 22px;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: #F3ECD9;
      margin: 0;
    }
    .note { margin: 0; font-size: 14.5px; max-width: 52ch; text-align: center; line-height: 1.5; }
    .note a { color: #E4C98F; }
    .phone {
      width: 412px;
      max-width: 100%;
      background: #111209;
      border-radius: 40px;
      padding: 11px;
      box-shadow: 0 24px 64px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(243, 236, 217, 0.12);
    }
    .phone iframe {
      display: block;
      width: 390px;
      max-width: 100%;
      height: 844px;
      max-height: calc(100vh - 220px);
      min-height: 500px;
      border: none;
      border-radius: 30px;
      background: #F7F1E3;
    }
    .back {
      font-family: Oswald, sans-serif;
      font-weight: 600;
      font-size: 13px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #23241A;
      background: #C08A34;
      text-decoration: none;
      border-radius: 3px;
      padding: 12px 22px;
    }
    .back:hover { background: #D49C44; }
  </style>
</head>
<body>
  <div class="head">
    <img src="/assets/img/seal-192.png" alt="">
    <h1>Mobile preview</h1>
    <p class="note">This is the same site rendered at phone width (390px) — on a real phone, <a href="/">the regular address</a> shows this layout automatically. Browse normally inside the frame.</p>
  </div>
  <div class="phone">
    <iframe src="/" title="Peninsula Fermentation Society — mobile layout"></iframe>
  </div>
  <a class="back" href="/">Open the full site →</a>
</body>
</html>
