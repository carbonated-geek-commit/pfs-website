---
layout: layouts/base.njk
navKey: resources
title: Resources
description: "The member library — recipes, forms, training aids, and past presentations, organized in one place."
permalink: /resources/
---
<section class="page-header">
  <div class="page-header__inner container">
    <div class="eyebrow">Member Resources</div>
    <h1 class="h1">The Library</h1>
    <p class="page-header__lede">Recipes, forms, training aids, and past presentations — organized in one place instead of scattered Drive folders.</p>
  </div>
</section>

<div class="members-banner">
  <div class="members-banner__inner container">
    <span class="members-banner__chip">Members Only</span>
    <span class="members-banner__text">Downloads require a member sign-in — file links are no longer public, and folder metadata stays private.</span>
    <a class="btn btn--cream members-banner__signin" href="{{ site.memberSignInUrl }}" data-analytics="member_signin_click">Member Sign-In</a>
  </div>
</div>

{% from "partials/file-list.njk" import fileRow %}
<section class="library">
  <div class="library__inner container">
    {% for col in library %}
    <div class="collection{% if loop.first %} is-open{% endif %}" id="{{ col.title | slugSafe }}">
      <button class="collection__header" type="button" aria-expanded="{% if loop.first %}true{% else %}false{% endif %}">
        <span class="collection__heading">
          <span class="collection__title">{{ col.title }}</span>
          <span class="collection__blurb">{{ col.blurb }}</span>
        </span>
        <span class="collection__chevron" aria-hidden="true">▾</span>
      </button>
      <div class="collection__body">
        {% for doc in col.items %}
        {{ fileRow(doc, col.title, site.memberSignInUrl) }}
        {% endfor %}
        <div class="collection__note">Sample items — synced from the club's document store.</div>
      </div>
    </div>
    {% endfor %}
  </div>
</section>
